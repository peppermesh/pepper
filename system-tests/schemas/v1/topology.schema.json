{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://peppermesh.org/schemas/system-test/v1/topology.schema.json",
  "title": "Pepper system test topology v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "network", "nodes"],
  "properties": {
    "schema_version": { "const": 1 },
    "run_id": { "type": "string", "minLength": 1, "maxLength": 256 },
    "profile": { "type": "string", "maxLength": 128 },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "subnet"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 256 },
        "subnet": { "type": "string", "minLength": 1, "maxLength": 128 },
        "mtu": { "type": ["integer", "null"], "minimum": 576, "maximum": 65535 },
        "internal": { "type": "boolean" }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": { "$ref": "#/$defs/node" }
    },
    "policies": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "replication_factor": { "type": "integer", "minimum": 1, "maximum": 64 },
        "erasure_data_shards": { "type": ["integer", "null"], "minimum": 1, "maximum": 32 },
        "erasure_parity_shards": { "type": ["integer", "null"], "minimum": 1, "maximum": 32 },
        "namespace_voter_count": { "type": ["integer", "null"], "minimum": 3, "maximum": 9 }
      }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name", "node_id", "address", "p2p_port", "api_port", "failure_domain",
        "bootstrap_nodes", "storage", "resources", "identity_fixture"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 128 },
        "node_id": { "type": ["string", "null"], "pattern": "^[0-9a-f]{64}$" },
        "address": { "type": "string", "minLength": 1, "maxLength": 256 },
        "p2p_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "api_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "failure_domain": { "type": "string", "minLength": 1, "maxLength": 256 },
        "placement_labels": { "type": "object", "additionalProperties": { "type": "string", "maxLength": 256 } },
        "bootstrap_nodes": { "type": "array", "items": { "type": "string", "maxLength": 128 }, "uniqueItems": true },
        "storage": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["volume", "capacity_bytes"],
            "properties": {
              "volume": { "type": "string", "minLength": 1, "maxLength": 256 },
              "capacity_bytes": { "type": "integer", "minimum": 1 }
            }
          }
        },
        "resources": {
          "type": "object",
          "additionalProperties": false,
          "required": ["cpu_limit", "memory_bytes", "tokio_workers"],
          "properties": {
            "cpu_limit": { "type": "number", "exclusiveMinimum": 0 },
            "memory_bytes": { "type": "integer", "minimum": 1048576 },
            "tokio_workers": { "type": "integer", "minimum": 1, "maximum": 64 }
          }
        },
        "identity_fixture": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "consensus_enabled": { "type": "boolean" },
        "compute_enabled": { "type": "boolean" }
      }
    }
  }
}
